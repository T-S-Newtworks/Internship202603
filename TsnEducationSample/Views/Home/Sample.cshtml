﻿@{
    ViewBag.Title = "サンプル";
}
<main aria-labelledby="title">
    <h2 id="title">@ViewBag.Title</h2>
    <div class="row">
        <h3>① 電卓</h3>
        <form name="dentaku">
            <table class="calcTable">
                <!-- 液晶画面部分 -->
                <tr>
                    <td colspan="4">
                        <input type="text" class="display" name="display" value="" disabled>
                    </td>
                </tr>

                <!-- 上から1段目（7~9＋÷） -->
                <tr>
                    <td><input type="button" class="calcBtn" value="7" onclick="get_calc(this)"></td>
                    <td><input type="button" class="calcBtn" value="8" onclick="get_calc(this)"></td>
                    <td><input type="button" class="calcBtn" value="9" onclick="get_calc(this)"></td>
                    <td><input type="button" value="÷" class="calcBtn operator" name="div_btn" onclick="get_calc(this)"></td>
                </tr>

                <!-- 上から2段目（4~6＋×） -->
                <tr>
                    <td><input type="button" class="calcBtn" value="4" onclick="get_calc(this)"></td>
                    <td><input type="button" class="calcBtn" value="5" onclick="get_calc(this)"></td>
                    <td><input type="button" class="calcBtn" value="6" onclick="get_calc(this)"></td>
                    <td><input type="button" value="×" class="calcBtn operator" name="multi_btn" onclick="get_calc(this)"></td>
                </tr>

                <!-- 上から3段目（1~3＋-） -->
                <tr>
                    <td><input type="button" class="calcBtn" value="1" onclick="get_calc(this)"></td>
                    <td><input type="button" class="calcBtn" value="2" onclick="get_calc(this)"></td>
                    <td><input type="button" class="calcBtn" value="3" onclick="get_calc(this)"></td>
                    <td><input type="button" value="-" class="calcBtn operator" onclick="get_calc(this)"></td>
                </tr>

                <!-- 上から4段目（0/C/=/+) -->
                <tr>
                    <td><input type="button" class="calcBtn" value="0" onclick="get_calc(this)"></td>
                    <td><input type="button" class="calcBtn" value="C" onclick="get_calc(this)"></td>
                    <td><input type="button" value="=" class="calcBtn equal" onclick="get_calc(this)"></td>
                    <td><input type="button" value="+" class="calcBtn operator" onclick="get_calc(this)"></td>
                </tr>

            </table>
        </form>
    </div>

    <hr />

    <div class="row">
        <h3>② JSON形式のオープンデータを活用した銀行名検索</h3>
        <form>
            <div class=" d-flex flex-row gap-2 mb-2">
                <!-- 銀行コード -->
                <div class="form-group">
                    <input type="text"
                           class="form-control"
                           placeholder="例：0000"
                           id="input-bankCode" />
                </div>

                <!-- 銀行名 -->
                <div class="form-group">
                    <input type="text"
                           class="form-control"
                           disabled
                           id="txt-bankName" />
                </div>

                <!-- 支店コード -->
                <div class="form-group">
                    <input type="text"
                           class="form-control"
                           placeholder="例：000"
                           id="input-branchCode" />
                </div>

                <!-- 支店名 -->
                <div class="form-group">
                    <input type="text"
                           class="form-control"
                           disabled
                           id="txt-branchName" />
                </div>
            </div>
            <button type="button" class="btn btn-primary mb-3" id="bankSearch">銀行検索</button>
        </form>
        <h4>銀行検索結果(JSON)</h4>
        <div>
            <!-- レスポンス表示部分 -->
            <div class="form-control mx-auto" style="min-height: 205px;">
                <pre id="api-result"></pre>
            </div>
        </div>
    </div>

    <hr />

    <div class="row">
        <h3>③ いい感じのグラフを表示する(ダッシュボード)</h3>
        @Html.ActionLink("ダッシュボードへ", "Index", "DashBoard", new { area = "" }, new { @class = "action-link" })
    </div>

    <hr />

    <div class="row">
        <h3>④ サーバ側の処理(TODOリスト)</h3>
        @Html.ActionLink("TODOリストへ", "Index", "Todo", new { area = "" }, new { @class = "action-link" })
    </div>
</main>
@section scripts{
    <script type="text/javascript">

        //#region 銀行検索
        //送信ボタンがクリックされたときの処理
        // 銀行名、支店名をAPIで取得
        $("#bankSearch").on("click", function () {
            UpdateBankAndBranchInfo($("#input-bankCode").val(), $("#input-branchCode").val());
        });

        /* APIのURL */
        const BankcodeBaseUrl = "https://apis.bankcode-jp.com/v3/";

        /**
         *  API認証キー
         * 補足：
         * 認証はリクエストパラメータまたはリクエストヘッダに設定されたAPIキーを介して実行されます。
         * すべてのAPIリクエストはHTTPSを介して行われる必要があります。
         * 認証なしのAPIリクエストを繰り返すと、クライアントIPアドレス、リファラに対してアクセス制限が発生します。
         * */
        const BankcodeJpApiKey = "9HQW3nN3DTK9xwTZ9Ha2WV2RikseSd";

        /**
         * 銀行コード・支店コードから自動で銀行名・支店名を取得してセット + JSON表示
         */
        function UpdateBankAndBranchInfo(bankcode, branchcode) {

            // 銀行コードが無い場合は両方クリア
            if (!bankcode) {
                $('#txt-bankName').val("");
                $('#txt-branchName').val("");
                $('#api-result').text("");
                return;
            }

            // 銀行情報取得
            let bankUrl = BankcodeBaseUrl + "banks/" + bankcode;

            ExecuteBankcodeApi('GET', bankUrl, function (bankData) {
                // JSON表示（銀行情報）
                $('#api-result').text(JSON.stringify(bankData, null, 2));

                if (bankData && Object.keys(bankData).length) {
                    $('#txt-bankName').val(bankData.halfWidthKana);
                } else {
                    $('#txt-bankName').val("");
                }

                // 支店コードがあれば支店情報も取得
                if (branchcode) {
                    let branchUrl = BankcodeBaseUrl + "banks/" + bankcode + "/branches/" + branchcode;

                    ExecuteBankcodeApi('GET', branchUrl, function (branchData) {
                        // JSON表示（支店情報）
                        $('#api-result').text(JSON.stringify(branchData, null, 2));

                        if (branchData && Object.keys(branchData).length) {
                            $('#txt-branchName').val(branchData.branch.halfWidthKana);
                        } else {
                            $('#txt-branchName').val("");
                        }
                    }, function () {
                        // 支店取得失敗時
                        $('#txt-branchName').val("");
                    });
                } else {
                    // 支店コードが無い場合はクリア
                    $('#txt-branchName').val("");
                }

            }, function () {
                // 銀行取得失敗時
                $('#txt-bankName').val("");
                $('#txt-branchName').val("");
                $('#api-result').text("");
            });
        }

        /**
         * APIの実行
         */
        function ExecuteBankcodeApi(type, url, successAction, errorAction = function () { }) {
            $.ajax({
                type: type,
                url: url,
                dataType: 'json',
                headers: {
                    'apikey': BankcodeJpApiKey,
                },
                cache: false, //キャッシュ無効化
                async: true,  //非同期
                success: function (data) {
                    successAction(data);
                },
                error: function (XMLHttpRequest) {
                    errorAction(XMLHttpRequest);
                }
            });
        }

        //#endregion

        //#region 電卓の処理
        function get_calc(btn) {
            if (btn.value == "=") {
                //末尾が数値ではない場合は計算しない
                if (isNaN(document.dentaku.display.value.slice(-1)) == true) {
                    return;
                }
                //表示されている文字を計算し、計算結果を表示する
                //TODO: evalはXSS等のセキュリティ脆弱性を突く攻撃につながるため余裕あれば別のものにする
                document.dentaku.display.value = eval(document.dentaku.display.value);
            } else if (btn.value == "C") {
                //表示されている文字を空にする
                document.dentaku.display.value = "";
            } else {
                if (btn.value == "×") {
                    //乗算演算子に変換
                    btn.value = "*";
                } else if (btn.value == "÷") {
                    //除算演算子に変換
                    btn.value = "/";
                }
                //表示文字の設定
                document.dentaku.display.value += btn.value;
                //変換した文字を元に戻す
                document.dentaku.multi_btn.value = "×";
                document.dentaku.div_btn.value = "÷";
            }
        }

        //#endregion</script>

    <style>
        .action-link {
            text-decoration: underline;
            padding-left: calc(var(--bs-gutter-x)* 0.5);
            font-size: 1.5rem;
            width: auto;
        }

        .calcTable {
            /* 電卓のサイズ */
            width: 300px;
            height: 400px;
            /* 電卓が浮き出るように影を付ける */
            border: solid 1px #dcdcdca4;
            border-right: solid 4px #dcdcdca4;
            border-bottom: solid 4px #dcdcdca4;
            border-radius: 10px;
            /* インライン要素を中央に配置 */
            text-align: center;
            /* 余白調整 */
            padding: 8px;
            margin: 20px;
        }

        .calcBtn {
            /* ボタンのサイズ */
            width: 70px;
            height: 70px;
            /* ボタンの文字サイズ */
            font-size: x-large;
            /* 数字部分の背景色 */
            background-color: #dcdcdca4;
            /* ボタンの詳細設定 */
            border: none;
            border-radius: 20px;
            /* クリック時の黒枠を消す */
            outline: none;
        }

        /* ディスプレイの詳細設定 */
        .display {
            width: 250px;
            text-align: right; /* 文字を右詰めに */
            /* 見た目の詳細設定 */
            background: #ffffff;
            border-top: solid #dcdcdca4 5px;
            border-bottom: solid #dcdcdca4 5px;
            border-right: solid #b6b6b6 6px;
            border-left: solid #b6b6b6 6px;
            border-radius: 5px;
        }
        /* 演算子の背景色を上書きで設定 */
        .operator {
            background-color: #87cefa;
        }
        /* 記号＝の部分の背景色を上書きで設定 */
        .equal {
            background-color: #b6b6b6;
        }

        /* カーソルを上に乗せた時に色を濃くする */
        .calcBtn:hover {
            background: #747373b9;
        }

        .display:hover {
            background: #ffffff; /* ディスプレイ部分は無効化 */
        }

        .operator:hover {
            background: #339cdd;
        }

        .operator:active {
            background: #2c80b4;
        }

        pre {
            margin: 0 !important;
        }

        /*書籍検索結果テーブルの設定*/
        .table-bordered th:first-child {
            width: 10%;
            min-width: 80px;
        }

        .table-bordered td:first-child {
            width: 10%;
            min-width: 80px;
        }
    </style>
}