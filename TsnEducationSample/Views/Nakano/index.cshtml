@model List<TsnEducationSample.Models.TodoItem>
@{
    ViewBag.Title = "サンプル";
}
<main aria-labelledby="title">
    <div class="row">
        <div class="d-flex flex-row justify-content-between mb-3">
            <h3>MyTodo</h3>
            @Html.ActionLink("サンプル一覧画面へ戻る", "Sample", "Home", new { area = "" }, new { @class = "dashboard-link" })
        </div>
        <form>
            <div class="d-flex flex-row gap-2">
                <input class="form-control" type="text" id="todoTitle" placeholder="タイトルを入力" />
                <input class="form-control" type="date" id="tododay" placeholder="期日の入力" />
                <button class="btn btn-primary w-auto text-nowrap" type="button" id="todoSubmit">TODO追加</button>
            </div>
        </form>
        <div id="todoListTable">
            @using (Html.BeginForm("SaveTodoItems", "Nakano", FormMethod.Post, new { @id = "LayoutForm" }))
            {
                <div style="display:flex; flex-direction:row; justify-content:space-between; align-items: center;">
                    <h4>TODOリスト一覧</h4>
                    <div class="d-flex flex-row gap-2">
                        <h4>TODOリスト一覧 <small class="text-muted">(残り <span id="taskCount">0</span> 件)</small></h4>
                        <button class="btn btn-info text-white" type="button" id="sortToday">当日優先ソート</button>
                        <button class="btn btn-primary" type="button" id="saveTodo">保存</button>
                    </div>
                </div>
                <table class="table table-bordered" id="todoTable">
                    <thead>
                        <tr>
                            <th scope="col">操作</th>
                            <th scope="col">タイトル</th>
                            <th scope="col">説明</th>
                            <th scope="col">期日</th>
                            <th scope="col">完了</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            @{
                                string style = string.Empty;
                                if (Model.Any()) { style = "display:none;"; }
                                <td colspan="5" id="defaultFirstRow" class="text-center" style="@style">表示する項目がありません。</td>
                            }
                        </tr>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <div class="d-flex flex-row justify-content-center gap-1">
                                        <button class="btn btn-outline-success btn-sm edit-btn" type="button">編集</button>
                                        <button class="btn btn-outline-danger btn-sm delete-btn" type="button">削除</button>
                                    </div>
                                </td>
                                <td><span class="todoContents">@item.Title</span></td>
                                <td><span class="todoContents">@item.Description</span></td>
                                <td><span class="todoContents">@item.day</span></td>
                                <td class="text-center"><input type="checkbox" class="todo-check"></td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</main>

@section scripts{
    <script type="text/javascript">

        // TODOを追加
        function addTasks(Title, day) {
            $('#defaultFirstRow').hide();
            var todoTableBody = $('#todoTable tbody')[0];
            var trElem = todoTableBody.insertRow(-1);

            // セルを作成(0:操作, 1:タイトル, 2:説明, 3:期日, 4:完了)
            var btnCell = trElem.insertCell(0);
            var titleCell = trElem.insertCell(1);
            var descCell = trElem.insertCell(2);
            var dayCell = trElem.insertCell(3);
            var checkCell = trElem.insertCell(4);

            // 操作列（横並びボタン）
            btnCell.className = "text-center";
            btnCell.innerHTML = `
                        <div class="d-flex flex-row justify-content-center gap-1">
                            <button class="btn btn-outline-success btn-sm edit-btn" type="button">編集</button>
                            <button class="btn btn-outline-danger btn-sm delete-btn" type="button">削除</button>
                        </div>`;

            // 各列にデータをセット（これで列ズレを防止）
            titleCell.innerHTML = `<span class="todoContents">${Title}</span>`;
            descCell.innerHTML = `<span class="todoContents"></span>`; // 説明は初期空
            dayCell.innerHTML = `<span class="todoContents">${day}</span>`;

            checkCell.className = "text-center";
            checkCell.innerHTML = '<input type="checkbox" class="todo-check">';

            checkOverdue();
            updateTaskCount(); // これを追加
        }

        function checkOverdue() {
            var now = new Date();
            var today = new Date(now.getFullYear(), now.getMonth(), now.getDate()).getTime();
            $('#todoTable tbody tr').each(function () {
                var row = $(this);
                var dateText = row.find('td').eq(3).text().trim();
                if (!dateText || dateText.includes("表示する項目")) return;
                var targetDate = new Date(dateText).getTime();
                if (targetDate < today) {
                    row.addClass('table-danger-light');
                    row.find('.todoContents').addClass('overdue');
                } else {
                    row.removeClass('table-danger-light');
                    row.find('.todoContents').removeClass('overdue');
                }
            });
        }

        // 編集・保存
        function editTask(editBtn) {
            var row = $(editBtn).closest('tr');
            var cells = [row.find('td').eq(1), row.find('td').eq(2)];
            cells.forEach(cell => {
                var currentText = cell.find('span').text();
                if (cell.find('input').length === 0) {
                    cell.html('<input type="text" class="form-control form-control-sm" value="' + currentText + '">');
                }
            });
            var dateCell = row.find('td').eq(3);
            var currentDate = dateCell.find('span').text().trim();
            dateCell.html('<input type="date" class="form-control form-control-sm" value="' + currentDate + '">');

            $(editBtn).text('保存').removeClass('btn-outline-success').addClass('btn-success');
        }

        function saveTask(saveBtn) {
            var row = $(saveBtn).closest('tr');
            for (var i = 1; i <= 3; i++) {
                var cell = row.find('td').eq(i);
                var val = cell.find('input').val();
                cell.html('<span class="todoContents">' + val + '</span>');
            }
            $(saveBtn).text('編集').removeClass('btn-success').addClass('btn-outline-success');
            checkOverdue();
        }

        function updateTaskCount() {
            // 全体の行数から「表示する項目がありません」の行を除いてカウント
            // または、チェックが入っていない（未完了）行だけを数える
            var count = $('#todoTable tbody tr').filter(function () {
                // デフォルト行を除外し、かつチェックボックスにチェックが入っていない行をカウント
                return $(this).find('td').length > 1 && !$(this).find('.todo-check').is(':checked');
            }).length;

            $('#taskCount').text(count);
        }
        // イベント設定
        $(document).on('click', '.edit-btn', function (e) {
            e.preventDefault();
            $(this).text() === '編集' ? editTask(this) : saveTask(this);
        });

        $(document).on('click', '.delete-btn', function (e) {
            e.preventDefault();

            // 確認ダイアログを表示
            if (confirm("このTODOを削除してもよろしいですか？")) {
                // 「OK」を押した場合のみ実行
                $(this).closest('tr').remove();

                // もし行が「表示する項目がありません」だけになったら再表示
                if ($('#todoTable tbody tr').length === 1) {
                    $('#defaultFirstRow').show();
                }
                updateTaskCount();
            }
            // 「キャンセル」を押した場合は何もしない
        });

        $('#sortToday').click(function () {
            var tbody = $('#todoTable tbody');
            var rows = tbody.find('tr').filter(function () { return $(this).find('td').length > 1; }).get();
            var now = new Date();
            var today = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}`;
            rows.sort(function (a, b) {
                var dateA = $(a).find('td').eq(3).text().trim();
                var dateB = $(b).find('td').eq(3).text().trim();
                if (dateA === today && dateB !== today) return -1;
                if (dateA !== today && dateB === today) return 1;
                return dateA.localeCompare(dateB);
            });
            $.each(rows, function (i, row) { tbody.append(row); });
        });

        function submitTodo() {
            var title = $('#todoTitle').val();
            var day = $('#tododay').val();

            // タイトルが空なら中断
            if (title.trim() === "") {
                alert("タイトルを入力してください");
                return;
            }
            // 期日が空なら中断
            if (day === "") {
                alert("期日を入力してください");
                return;
            }

            addTasks(title, day);

            // 入力欄をリセット
            $('#todoTitle').val('');
            $('#tododay').val('');
        }

        $('#todoSubmit').click(submitTodo);
        $('#todoTitle').keypress(function (e) { if (e.which === 13) { e.preventDefault(); submitTodo(); } });
        $(document).ready(checkOverdue);

        $(document).on('change', '.todo-check', function () {
            var row = $(this).closest('tr');
            $(this).is(':checked') ? row.find('.todoContents').addClass('completed-task') : row.find('.todoContents').removeClass('completed-task');
            updateTaskCount();
        });

        //$('#saveTodo').click(function () {

        //    // データ行（タイトル等がある行）をすべて取得
        //    var rows = $('#todoTable tbody tr').filter(function () {
        //        return $(this).find('td').length > 1;
        //    });

        //    rows.each(function (index) {
        //        var row = $(this);
        //        var isChecked = row.find('.todo-check').is(':checked');

        //        if (isChecked) {
        //            // 【完了】チェックがついている場合は、その行を削除して保存対象から外す
        //            row.remove();
        //        } else {
        //            // チェックがついていない場合のみ、サーバー送信用の隠しフィールドを作る
        //            var title = row.find('td').eq(1).find('span').text();
        //            var desc = row.find('td').eq(2).find('span').text();
        //            var day = row.find('td').eq(3).find('span').text(); // 期日も送るなら追加

        //            // 既存の古いhiddenがあれば一旦消す（重複防止）
        //            row.find('input[type="hidden"]').remove();

        //            row.append(`<input type="hidden" name="todoItems[${index}].Title" value="${title}">`);
        //            row.append(`<input type="hidden" name="todoItems[${index}].Description" value="${desc}">`);
        //            row.append(`<input type="hidden" name="todoItems[${index}].day" value="${day}">`);
        //        }
        //    });

        //    // 全行消えた場合に「表示する項目がありません」を再表示
        //    if ($('#todoTable tbody tr').filter(function () { return $(this).find('td').length > 1; }).length === 0) {
        //        $('#defaultFirstRow').show();
        //    }

        //    updateTaskCount();

        //    // 最後にフォームを送信
        //    $('#LayoutForm').submit();
        //});

        $('#saveTodo').click(function () {
            // 1. まずチェックが入っている行（完了済み）を物理的に削除する
            $('#todoTable tbody tr').each(function () {
                if ($(this).find('.todo-check').is(':checked')) {
                    $(this).remove();
                }
            });

            // 2. 生き残った「未完了」の行だけを取得し直す
            var remainingRows = $('#todoTable tbody tr').filter(function () {
                return $(this).find('td').length > 1; // デフォルト行を除外
            });

            // 3. 残った行に対して、改めて 0 から順番に連番を振る
            remainingRows.each(function (newIndex) {
                var row = $(this);

                // 既存のhiddenがあれば削除（二重登録防止）
                row.find('input[type="hidden"]').remove();

                var title = row.find('td').eq(1).find('span').text();
                var desc = row.find('td').eq(2).find('span').text();
                var day = row.find('td').eq(3).find('span').text();

                // newIndex を使うことで [0], [1], [2]... と隙間なく番号が振られる
                row.append(`<input type="hidden" name="todoItems[${newIndex}].Title" value="${title}">`);
                row.append(`<input type="hidden" name="todoItems[${newIndex}].Description" value="${desc}">`);
                row.append(`<input type="hidden" name="todoItems[${newIndex}].day" value="${day}">`);
            });

            // 4. カウント更新と表示制御
            if (remainingRows.length === 0) {
                $('#defaultFirstRow').show();
            }
            updateTaskCount();

            // 5. 隙間のないデータになったので、安心して送信
            $('#LayoutForm').submit();
        });


        $(document).ready(function () {
            checkOverdue();
            updateTaskCount(); // 初期表示時のカウント
        });
    </script>

    <style>
        .dashboard-link {
            text-decoration: underline;
            font-size: 1.5rem;
        }

        /* 4番目の列（期日）の幅を狭くする */
        #todoTable th:nth-child(4),
        #todoTable td:nth-child(4) {
            width: 120px;
        }

        /* 5番目の列（完了）の幅を最小限にする */
        #todoTable th:nth-child(5),
        #todoTable td:nth-child(5) {
            width: 60px;
            text-align: center;
        }

        #todoListTable {
            width: 100%;
            margin-top: 2rem;
        }
        /* 操作列の幅を固定して横並びを維持 */
        #todoTable th:first-child, #todoTable td:first-child {
            width: 160px;
            min-width: 160px;
        }

        .completed-task {
            text-decoration: line-through;
            color: #adb5bd;
        }

        .todo-check {
            transform: scale(1.3);
            cursor: pointer;
        }

        .overdue {
            color: #dc3545 !important;
            font-weight: bold;
        }

        .table-danger-light {
            background-color: #fff2f2 !important;
        }

        .form-control-sm {
            height: 30px;
        }
    </style>
}